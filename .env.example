# Discord OAuth - คัดลอกจาก Discord Developer Portal
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# URL ของเว็บ (ตอน dev = http://localhost:3000)
APP_URL=http://localhost:3000

# Random string สำหรับเซ็น cookie (ใช้คำสั่ง: openssl rand -hex 32)
SESSION_SECRET=please_change_this_to_random_string

# Vercel KV - ได้อัตโนมัติเมื่อสร้าง KV database บน Vercel
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
